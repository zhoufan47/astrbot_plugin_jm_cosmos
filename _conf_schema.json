{
    "domain_list": {
        "description": "禁漫镜像站域名列表",
        "type": "list",
        "hint": "可访问的禁漫镜像站域名，不需要添加http或https前缀，默认参数jmcomic-zzz.one，建议不要修改",
        "default": ["jmcomic-zzz.one"]
    },
    "mode":{
      "description": "下载模式",
      "hint":"APP端不限ip兼容性好，网页端限制ip地区但效率高",
      "options": ["html", "api"],
      "type": "string",
      "default":"html"
    },
    "proxy": {
        "description": "代理服务器",
        "type": "string",
        "hint": "访问禁漫网站的代理服务器，格式为: http://127.0.0.1:7890",
        "obvious_hint": true,
        "default": ""
    },
    "avs_cookie": {
        "description": "AVS Cookie",
        "type": "string",
        "hint": "登录后的Cookie值，用于获取更多内容",
        "default": ""
    },
    "jm_username": {
        "description": "JM用户名",
        "type": "string",
        "hint": "用于用户登录",
        "default": ""
    },
    "jm_passwd": {
        "description": "JM密码",
        "type": "string",
        "hint": "用于用户登录",
        "default": ""
    },
    "is_jm_login": {
        "description": "是否使用账密登录JM",
        "type": "bool",
        "hint": "是否使用账密登录JM，否则使用cookies",
        "default": false
    },
    "max_threads": {
        "description": "最大下载线程数",
        "type": "int",
        "hint": "同时下载的最大线程数，建议不超过20",
        "default": 10
    },
    "show_cover": {
        "description": "显示封面图片",
        "type": "bool",
        "hint": "是否在漫画信息和搜索结果中显示封面图片",
        "default": true
    },
    "debug_mode": {
        "description": "调试模式",
        "type": "bool",
        "hint": "启用调试模式后会保存更多日志信息，帮助排查问题",
        "default": false
    },
      "is_discord_post": {
        "description": "是否转发discord",
        "type": "bool",
        "hint": "需要搭配DiscordPoster工具使用",
        "default": false
    },
      "discord_poster_api_url": {
        "description": "DiscordPoster工具API",
        "type": "string",
        "hint": "DiscordPoster工具API的地址",
        "default": ""
    },
  "pdf_password": {
    "description": "PDF密码",
    "type": "string",
    "hint": "PDF密码，用于加密的PDF文件",
    "default": "123"
  },
  "llm_provider_id": {
        "description": "用于分析画像的LLM提供商",
        "hint": "用于性癖调查功能中生成AI分析评论的LLM提供商ID。留空则使用当前默认对话模型。",
        "type": "string",
        "default": "",
        "_special": "select_provider"
    }
} 